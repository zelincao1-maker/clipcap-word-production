NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BYPASS_LOGIN_FOR_LOCAL=false
# JSON preview debug toggle:
# This is controlled in the browser console, not by env vars.
# Use these commands on the slot-review / generation-review pages:
#   window.clipcapJsonPreview.show()
#   window.clipcapJsonPreview.hide()
#   window.clipcapJsonPreview.toggle()
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
TEXT_LLM_API_KEY=your_text_llm_api_key
TEXT_LLM_BASE_URL=https://your-text-llm-base-url.example.com/v1
TEXT_LLM_MODEL=your_text_llm_model
# You can keep TEXT_LLM_* and VISION_LLM_* as separate variables
# even when both point to the same provider/model, for example Kimi:
# TEXT_LLM_API_KEY=your_moonshot_api_key
# TEXT_LLM_BASE_URL=https://api.moonshot.cn/v1
# TEXT_LLM_MODEL=kimi-k2.5
VISION_LLM_API_KEY=your_vision_llm_api_key
VISION_LLM_BASE_URL=https://your-vision-llm-base-url.example.com/v1
VISION_LLM_MODEL=your_vision_llm_model
# VISION_LLM_API_KEY=your_moonshot_api_key
# VISION_LLM_BASE_URL=https://api.moonshot.cn/v1
# VISION_LLM_MODEL=kimi-k2.5
